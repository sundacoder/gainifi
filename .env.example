# ──────────────────────────────────────────────────
# Gainifi — Environment Variables
# Stablecoin Exchange + Nanopayments on Arc
# ──────────────────────────────────────────────────

# Supabase (for user auth + transaction history)
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Circle Developer Controlled Wallets
# Get from https://console.circle.com
CIRCLE_API_KEY=your-circle-api-key
CIRCLE_ENTITY_SECRET=your-circle-entity-secret

# Arc Testnet RPC (optional, default public RPC used)
ARC_TESTNET_RPC_KEY=c0ca2582063a5bbd5db2f98c139775e982b16919

# Deployed Contract Addresses (update after running deploy scripts)
NEXT_PUBLIC_NANO_CHANNEL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STABLEFX_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USYC_VAULT_ADDRESS=0x0000000000000000000000000000000000000000